# fastlane/Deliverfile
# Default configuration for deliver (upload_to_app_store).

app_identifier "com.eouw0o83hf.synaesthetic"
username ENV.fetch("APPLE_ID", "")

submit_for_review true
automatic_release false
force true

# App Store metadata paths
screenshots_path "fastlane/screenshots"
metadata_path "fastlane/metadata"

# Support and Privacy URLs (populated by init.sh via GitHub Pages)
# These become the URLs shown on your App Store listing.
support_url "https://eouw0o83hf.github.io/synaesthetic/support"
privacy_url "https://eouw0o83hf.github.io/synaesthetic/privacy"

