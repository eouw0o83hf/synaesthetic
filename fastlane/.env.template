# fastlane/.env.template
# ─────────────────────────────────────────────────────────────────────────────
# USAGE: Copy this file to fastlane/.env and fill in your real values.
#
#   cp fastlane/.env.template fastlane/.env
#
# fastlane/.env is gitignored and will NEVER be committed.
# This template file IS committed — it documents every value that is required.
#
# The init.sh script copies this file to .env and pre-fills what it can.
# You must fill in the remaining values (passwords, API keys) manually.
# ─────────────────────────────────────────────────────────────────────────────

# ── Apple Developer credentials ───────────────────────────────────────────────
# Your Apple ID (the email you use to log in to developer.apple.com and
# App Store Connect). Used by fastlane to authenticate without a password
# when combined with an App Store Connect API Key.
APPLE_ID=

# Your 10-character Apple Developer Team ID.
# Find it at developer.apple.com → Account → Membership → Team ID
APPLE_TEAM_ID=

# ── fastlane match (code signing) ────────────────────────────────────────────
# SSH URL of the private git repo where match stores your certificates.
# Example: git@github.com:your-org/your-app-certs.git
MATCH_GIT_URL=

# Passphrase used to encrypt and decrypt the certificates in the match repo.
# Choose a strong random passphrase. Store it in a password manager.
# All machines and CI runners that need to sign code must have this value.
MATCH_PASSWORD=

# ── App Store Connect API Key ─────────────────────────────────────────────────
# Required for uploading builds and fetching build info without a password or
# 2FA prompt. Generate at:
#   App Store Connect → Users and Access → Integrations → App Store Connect API
# Role needed: App Manager (minimum for uploads + TestFlight management)

# The Key ID shown on the API keys page (10-char alphanumeric)
APP_STORE_CONNECT_API_KEY_ID=

# The Issuer ID shown at the top of the API keys page (UUID format)
APP_STORE_CONNECT_API_KEY_ISSUER_ID=

# LOCAL: Absolute path to the downloaded .p8 key file.
# Used when running fastlane commands locally.
# After downloading: mv ~/Downloads/AuthKey_XXXXX.p8 ~/.appstore/
APP_STORE_CONNECT_API_KEY_PATH=

# CI: Base64-encoded contents of the .p8 key file.
# Used in GitHub Actions secrets (can't store file paths in CI secrets).
# Generate with: cat AuthKey_XXXXX.p8 | base64 | tr -d '\n'
# Then paste the result as a GitHub Actions secret named APP_STORE_CONNECT_API_KEY_CONTENT
# APP_STORE_CONNECT_API_KEY_CONTENT=

# ── GitHub Actions CI secrets (reference only — set in GitHub repo settings) ──
# These are NOT read from this file in CI; they're set as encrypted GitHub
# Actions secrets. Listed here for documentation purposes.
#
# MATCH_GIT_PRIVATE_KEY   SSH private key with access to the match certs repo
# KEYCHAIN_PASSWORD        Any random password for the temp CI keychain
# APP_STORE_CONNECT_API_KEY_CONTENT  Base64-encoded .p8 key (from above)

# ── Notifications (optional) ──────────────────────────────────────────────────
# Slack incoming webhook URL for build notifications.
# Create at: api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=

# ── Locale ────────────────────────────────────────────────────────────────────
# Fixes fastlane locale warnings on some systems.
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
