# ── Xcode ────────────────────────────────────────────────────────────────────

# Generated by XcodeGen — never commit these
*.xcodeproj/
*.xcworkspace/

# User-specific
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint
*.xcdebugger

# Build products
build/
DerivedData/
*.build/
*.app/
*.ipa
*.dSYM/
*.dSYM.zip

# Instruments
timeline.xctimeline
playground.xcworkspace

# ── Swift Package Manager ─────────────────────────────────────────────────────

.build/
.swiftpm/
Package.resolved  # only gitignore if you want unpinned dependencies

# ── fastlane ─────────────────────────────────────────────────────────────────

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/screenshots/**/*.jpg
fastlane/test_output/
fastlane/.env            # local secrets — never commit
fastlane/.env.*          # any .env variant
!fastlane/.env.template  # but DO commit the template

# ── Credentials & Secrets ─────────────────────────────────────────────────────

.env
.env.local
.env.*.local
*.p8                   # App Store Connect API keys
*.p12                  # Certificates with private keys
*.mobileprovision      # Provisioning profiles
AuthKey_*.p8

# ── macOS ─────────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Ruby ──────────────────────────────────────────────────────────────────────

.bundle/
vendor/bundle/
Gemfile.lock           # Uncomment to unpin gems (not recommended)

# ── Misc ──────────────────────────────────────────────────────────────────────

*.log
*.tmp
*.bak
dSYMs/
TestResults.xcresult/
